{
  "name": "hippocove-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Hippocove local workbench desktop shell",
  "author": "Aryuan026",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "node ./node_modules/electron/cli.js .",
    "pack:dir": "node ./node_modules/electron-builder/cli.js --dir",
    "pack:win": "node ./node_modules/electron-builder/cli.js --win portable --x64",
    "pack:win:installer": "node ./node_modules/electron-builder/cli.js --win nsis --x64",
    "pack:mac": "node ./node_modules/electron-builder/cli.js --mac dmg zip"
  },
  "devDependencies": {
    "electron": "^36.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hippocove.desktop",
    "productName": "Hippocove",
    "electronVersion": "35.7.5",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.mjs",
      "index.html",
      "ui/**/*",
      "legacy/**/*",
      "server/**/*",
      "docs/**/*",
      "README.md",
      "PROJECT_STATUS.md",
      "!data/**",
      "!output/**",
      "!tmp/**",
      "!**/.DS_Store"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "artifactName": "Hippocove-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
